// Entities
// Patients - store details of patients and role of the patient
// Doctors - patients with roles doctor (speciality is also stored)
// Departments - info about each department
// Appointments - Meeting between doctor and patient (status, doctor, patient, are test prescibed, is a consultation session)
// Tests - info about tests prescribed in a session by which doctor
// Reports - info of the report of each test
// Payments - payment depend on type of session and if there is any test prescribed

// Relationships
// patient < appointments
// doctor <> patients
// consultation < tests

patients [color: Green] {
  id uuid pk
  username text unique
  name text 
  email text unique
  password text 
  dob timestamp
  role check(patient, doctor, admin)
  doctor_id uuid fk
  mobile_no text
  reset_password_token text
  refresh_token text

  created_at timestamp
  updated_at timestamp
}

doctors [color: Orange] {
  id uuid pk
  speciality text
  department_id uuid fk

  created_at timestamp
  updated_at timestamp
}

departments [color: Green] {
  id uuid pk
  name text 
  room_no number // in which room the department is situated
  department_head text

  created_at timestamp
  updated_at timestamp
}

appointments [color: Blue] {
  id uuid pk
  scheduled_date timestamp
  scheduled_duration timestamp
  patient_id uuid fk
  doctor_id uuid fk
  type check(consultation, follow_up_visit, lab_test_visit)
  consultation_id uuid fk null
  lab_test_visit_id uuid fk null
  follow_up_visit_id uuid fk null

  created_at timestamp
  updated_at timestamp
}

consulutations [color: Orange] {
  id uuid pk
  test_id uuid fk null
  price number

  created_at timestamp
  updated_at timestamp
}

lab_test_visit [color: Purple] {
  id uuid pk
  name text
  report_id uuid fk
  patients_id uuid fk

  created_at timestamp
  updated_at timestamp
}

follow_up_visit [color: Yellow] {
  id uuid pk
  report_follow_up bool
  report_id uuid fk null
  price number null

  created_at timestamp
  updated_at timestamp
}

tests[color: Blue] {
  id uuid pk
  name text
  price number

  created_at timestamp
  updated_at timestamp
}

reports [color: Green] {
  id uuid pk
  report_result_scheduled timestamp

  created_at timestamp
  updated_at timestamp
}

payments [color: Red] {
  id uuid pk
  method check(credit_card, debit_card, upi)
  amount number
  patient_id uuid fk
  appointment_id uuid fk 

  status check(success, pending)
}

patients.doctor_id - doctors.id
doctors.department_id > departments.id

appointments.patient_id > patients.id
appointments.doctor_id > doctors.id

appointments.consultation_id - consulutations.id
appointments.lab_test_visit_id - lab_test_visit.id
appointments.follow_up_visit_id - follow_up_visit.id

follow_up_visit.report_follow_up > reports.id

consulutations.test_id <> tests.id

tests.id <> lab_test_visit.id
lab_test_visit.patients_id - patients.id

payments.patient_id > patients.id
payments.appointment_id > appointments.id


